# Zeniqle Client Acquisition System - Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3000

# CORS
CORS_ORIGIN=*

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=zeniqle_acquisition
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_SSL=false

# Redis (for caching and job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication (for future auth implementation)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# Email Service Provider (for future email integration)
# SENDGRID_API_KEY=SG.xxx
# POSTMARK_API_KEY=xxx

# CRM Webhook Secrets (for verifying incoming webhooks)
# HUBSPOT_WEBHOOK_SECRET=xxx
# SALESFORCE_WEBHOOK_SECRET=xxx

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined
