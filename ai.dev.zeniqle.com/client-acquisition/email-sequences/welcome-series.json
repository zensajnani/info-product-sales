      "preheader": "See the impact in your industry",
      "html_template": "welcome_04.html",
      "text_template": "welcome_04.txt",
      "personalization": ["first_name", "industry", "similar_company"],
      "goal": "Build trust with social proof"
    },
    {
      "id": "welcome_05",
      "delay": "+14 days",
      "subject_lines": [
        "Ready to talk strategy, {{first_name}}?",
        "Let's explore your specific needs",
        "{{first_name}}, quick question..."
      ],
      "preheader": "15 minutes could change your quarter",
      "html_template": "welcome_05.html",
      "text_template": "welcome_05.txt",
      "personalization": ["first_name", "engagement_score"],
      "goal": "Convert to demo/trial"
    }
